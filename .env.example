# === Hugging Face Configuration ===
# Required to download the gated medical AI models (MedGemma, TxGemma, etc.)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# === Application Configuration ===
# Set to True to bypass AI inference and load past real analyses from the Medical Vault
# Useful for fast demonstrations without waiting for model generation.
DEMO_MODE=False

# === Server Configuration ===
HOST=0.0.0.0
PORT=8000
